{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "env:dev": "ln -sf .env.development .env",
    "env:staging": "ln -sf .env.staging .env",
    "env:prod": "ln -sf .env.production .env",
    "start:dev": "npm run env:dev && npm start -- --reset-cache",
    "start:staging": "npm run env:staging && npm start -- --reset-cache",
    "start:prod": "npm run env:prod && npm start -- --reset-cache",
    "build:android:staging": "npm run env:staging && npm run clean && cd android && ./gradlew assembleRelease",
    "build:android:prod": "npm run env:prod && npm run clean && cd android && ./gradlew assembleRelease",
    "build:android:staging:bundle": "npm run env:staging && npm run clean && cd android && ./gradlew bundleRelease",
    "build:android:prod:bundle": "npm run env:prod && npm run clean && cd android && ./gradlew bundleRelease",
    "build:ios:staging": "npm run env:staging && npx react-native build-ios --mode Release",
    "build:ios:prod": "npm run env:prod && npx react-native build-ios --mode Release",
    "clean": "watchman watch-del-all && rm -rf $TMPDIR/metro-cache && cd android && ./gradlew clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native/new-app-screen": "0.84.1",
    "@types/yup": "^0.29.14",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-code-push": "^9.0.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-vector-icons": "^10.3.0",
    "socket.io-client": "^4.8.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}